            "new_string": "No memory leak because `elementMap` already has a 50-element cap with eviction.\n\n### 8.5 React Version Detection\n\nReact 19 removed `_debugOwner` from fibers, breaking the `walkComponentChain` traversal that identifies Mantine component props. The inspector must detect the React version at initialization and use a version-adaptive fiber walker.\n\n**Detection (during `activate()`):**\n\n```javascript\nvar reactVersion = null;\n\nfunction detectReactVersion() {\n  // Method 1: Check React.version if available on window\n  if (window.React && window.React.version) {\n    reactVersion = window.React.version;\n    return;\n  }\n  // Method 2: Check DevTools hook (works even without window.React)\n  var hook = window.__REACT_DEVTOOLS_GLOBAL_HOOK__;\n  if (hook && hook.renderers) {\n    hook.renderers.forEach(function (renderer) {\n      if (renderer.version) reactVersion = renderer.version;\n    });\n  }\n}\n```\n\n**Version-adaptive `walkComponentChain`:**\n\n```javascript\nfunction walkComponentChain(fiber) {\n  var chain = [];\n  var depth = 0;\n  var major = reactVersion ? parseInt(reactVersion.split('.')[0], 10) : 18;\n\n  if (major <= 18) {\n    // React ≤18: _debugOwner chain\n    var owner = fiber._debugOwner;\n    while (owner && depth < MAX_CHAIN_DEPTH) {\n      var name = getComponentName(owner);\n      if (name) chain.push(name);\n      owner = owner._debugOwner;\n      depth++;\n    }\n  } else {\n    // React 19+: fiber.return traversal (no _debugOwner)\n    var current = fiber.return;\n    while (current && depth < MAX_CHAIN_DEPTH) {\n      if (typeof current.type === 'function' || typeof current.type === 'object') {\n        var name = getComponentName(current);\n        if (name) chain.push(name);\n      }\n      current = current.return;\n      depth++;\n    }\n  }\n  return chain;\n}\n```\n\n**Fallback:** If version detection fails, default to React 18 behavior (`_debugOwner`). If `_debugOwner` returns empty results, automatically retry with `fiber.return` traversal. This ensures graceful degradation without requiring an explicit version number.\n\n---\n\n## 9. Edge Cases",
