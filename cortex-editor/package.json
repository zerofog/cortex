{
  "name": "cortex-editor",
  "version": "0.1.0",
  "description": "Visual refinement editor for web applications — Vite & Next.js plugin",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/parser": "^7.27.0",
    "magic-string": "^0.30.21",
    "@types/node": "^20",
    "happy-dom": "^15.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "tailwindcss": ">=3.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  }
}
