{
  "name": "cortex-editor",
  "version": "0.1.0",
  "description": "Visual refinement editor for web applications — Vite & Next.js plugin",
  "type": "module",
  "sideEffects": [
    "src/browser/types.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cortex": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite/vite.d.ts",
        "default": "./dist/vite/vite.js"
      },
      "require": {
        "types": "./dist/vite/vite.d.cts",
        "default": "./dist/vite/vite.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next/next.d.ts",
        "default": "./dist/next/next.js"
      },
      "require": {
        "types": "./dist/next/next.d.cts",
        "default": "./dist/next/next.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:test": "cross-env CORTEX_TEST_BUILD=true tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npm run build:test && playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/e2e/tsconfig.json",
    "prepublishOnly": "cross-env CORTEX_TEST_BUILD=false npm run build"
  },
  "devDependencies": {
    "@babel/parser": "^7.27.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.0.0",
    "cross-env": "^10.1.0",
    "happy-dom": "^15.0.0",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": ">=3.0.0",
    "vite": ">=5.1.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "postcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "preact": "^10.29.0",
    "tinykeys": "3.0.0",
    "ts-morph": "^27.0.2",
    "vanilla-colorful": "^0.7.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
