{
  "name": "cortex-editor",
  "version": "0.2.0",
  "description": "Visual editor for Claude Code",
  "license": "MIT",
  "author": "Zerofog",
  "homepage": "https://github.com/zerofog/cortex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerofog/cortex.git",
    "directory": "cortex-editor"
  },
  "bugs": {
    "url": "https://github.com/zerofog/cortex/issues"
  },
  "keywords": [
    "visual-editor",
    "design-tokens",
    "vite-plugin",
    "webpack-plugin",
    "nextjs",
    "css",
    "tailwindcss",
    "claude-code",
    "mcp",
    "devtools"
  ],
  "type": "module",
  "sideEffects": [
    "src/browser/types.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cortex": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite/vite.d.ts",
        "default": "./dist/vite/vite.js"
      },
      "require": {
        "types": "./dist/vite/vite.d.cts",
        "default": "./dist/vite/vite.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next/next.d.ts",
        "default": "./dist/next/next.js"
      },
      "require": {
        "types": "./dist/next/next.d.cts",
        "default": "./dist/next/next.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack/webpack.d.ts",
        "default": "./dist/webpack/webpack.js"
      },
      "require": {
        "types": "./dist/webpack/webpack.d.cts",
        "default": "./dist/webpack/webpack.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:test": "cross-env CORTEX_TEST_BUILD=true tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:perf": "vitest run --no-file-parallelism --project server tests/adapters/source-transform.test.ts tests/adapters/vite.test.ts",
    "test:watch": "vitest",
    "test:e2e": "npm run build:test && playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json && tsc --noEmit -p tests/e2e/tsconfig.json",
    "prepublishOnly": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && cross-env CORTEX_TEST_BUILD=false CORTEX_PUBLISH=true npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.0.0",
    "cross-env": "^10.1.0",
    "happy-dom": "^15.0.0",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "webpack": ">=5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": ">=3.0.0",
    "vite": ">=5.1.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "postcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "@floating-ui/dom": "^1.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "preact": "^10.29.0",
    "tinykeys": "3.0.0",
    "ts-morph": "^27.0.2",
    "vanilla-colorful": "^0.7.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
